{
  "name": "vgc-obs-overlay-generator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/next.cjs dev --webpack",
    "build": "prisma generate && node ./scripts/next.cjs build --webpack",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "next": "16.2.6",
    "postcss": "8.5.10",
    "prisma": "^6.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
